@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>ContosoPizza - Faça seu Pedido</title>
    <style>
        body { font-family: Arial; padding: 20px; max-width: 600px; margin: auto; }
        input, select, button { margin: 5px; padding: 8px; width: 100%; }
        .pizza-item { border: 1px solid #ddd; padding: 10px; margin: 10px 0; }
        button { background: #e67e22; color: white; border: none; cursor: pointer; }
    </style>
</head>
<body>
    <h1>🍕 ContosoPizza</h1>
    
    <h2>Cardápio</h2>
    <div id="cardapio"></div>

    <h2>Seus Dados</h2>
    <input type="text" id="nome" placeholder="Seu nome">
    <input type="text" id="endereco" placeholder="Seu endereço">
    <input type="text" id="telefone" placeholder="Seu telefone">

    <h2>Seu Pedido</h2>
    <div id="itensPedido"></div>
    <button onclick="adicionarPizza()">+ Adicionar Pizza</button>
    <button onclick="finalizarPedido()" style="background:green">✅ Finalizar Pedido</button>

    <script>
        let pizzas = [];

        // Carregar cardápio
        fetch('/api/pizza')
            .then(res => res.json())
            .then(data => {
                pizzas = data;
                const div = document.getElementById('cardapio');
                div.innerHTML = pizzas.map(p => `<div class="pizza-item">${p.name} - R$ ${p.price}</div>`).join('');
            });

        function adicionarPizza() {
            const container = document.getElementById('itensPedido');
            const id = Date.now();
            const div = document.createElement('div');
            div.className = 'pizza-item';
            div.innerHTML = `
                <select id="sabor_${id}">
                    <option value="">Selecione</option>
                    ${pizzas.map(p => `<option value="${p.name}">${p.name} - R$ ${p.price}</option>`).join('')}
                </select>
                <select id="tamanho_${id}">
                    <option value="Pequena">Pequena</option>
                    <option value="Média">Média (+R$5)</option>
                    <option value="Grande">Grande (+R$10)</option>
                </select>
                <input type="number" id="qtd_${id}" value="1" min="1" style="width:80px">
                <button onclick="this.parentElement.remove()">Remover</button>
            `;
            container.appendChild(div);
        }

        function finalizarPedido() {
            const itens = [];
            document.querySelectorAll('#itensPedido .pizza-item').forEach(item => {
                const sabor = item.querySelector('select')?.value;
                const tamanho = item.querySelectorAll('select')[1]?.value;
                const qtd = parseInt(item.querySelector('input')?.value || 0);
                if (sabor && qtd > 0) itens.push({ sabor, tamanho, quantidade: qtd });
            });

            if (itens.length === 0) { alert("Adicione pelo menos uma pizza!"); return; }

            const nome = document.getElementById('nome').value;
            const endereco = document.getElementById('endereco').value;
            const telefone = document.getElementById('telefone').value;

            if (!nome || !endereco || !telefone) { alert("Preencha todos os dados!"); return; }

            const pedido = { nomeCliente: nome, endereco, telefone, metodoPagamento: "Dinheiro", itens };

            fetch('/Home/FazerPedido', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(pedido)
            })
            .then(res => res.text())
            .then(html => document.body.innerHTML = html)
            .catch(err => alert("Erro: " + err.message));
        }
    </script>
</body>
</html>

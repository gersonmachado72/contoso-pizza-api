@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ContosoPizza - Cardápio Digital</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        /* Garante que os estilos não quebrem a página */
        .pizzas-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 20px;
            margin-top: 20px;
        }
        .pizza-card {
            border: 1px solid #ddd;
            border-radius: 12px;
            padding: 15px;
            text-align: center;
            background: white;
        }
        .price {
            color: #e67e22;
            font-size: 1.3rem;
            font-weight: bold;
        }
        .btn-adicionar {
            background: #27ae60;
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 25px;
            cursor: pointer;
            margin: 10px 0;
        }
        .btn-enviar {
            background: #e67e22;
            color: white;
            border: none;
            padding: 12px 30px;
            border-radius: 30px;
            cursor: pointer;
            margin-top: 20px;
        }
        .item-pedido {
            background: #f9f9f9;
            padding: 15px;
            margin: 10px 0;
            border-radius: 10px;
            border-left: 4px solid #e67e22;
        }
        .payment-option {
            display: inline-block;
            padding: 10px 15px;
            margin: 5px;
            border: 2px solid #ddd;
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.3s;
        }
        .payment-option.selected {
            border-color: #e67e22;
            background: #fef5e8;
        }
        .form-group {
            margin-bottom: 15px;
        }
        .form-control {
            width: 100%;
            padding: 10px;
            border: 1px solid #ccc;
            border-radius: 8px;
        }
    </style>
</head>
<body>
    <header class="main-header">
        <div class="header-container">
            <div class="site-name">🍕 ContosoPizza</div>
            <div class="logo-area">
                <img src="/images/logo.jpg" alt="Logo" class="logo-img" style="height:50px">
                <span>Qualidade que dá gosto!</span>
            </div>
        </div>
    </header>

    <div class="container">
        <h2>📋 Nosso Cardápio</h2>
        <div id="pizzas-list" class="pizzas-grid">Carregando...</div>

        <h2>📝 Faça seu Pedido</h2>
        <div class="form-group">
            <label>Nome completo:</label>
            <input type="text" id="nomeCliente" class="form-control">
        </div>
        <div class="form-group">
            <label>Endereço para entrega:</label>
            <input type="text" id="endereco" class="form-control">
        </div>
        <div class="form-group">
            <label>Telefone:</label>
            <input type="tel" id="telefone" class="form-control">
        </div>
        <div class="form-group">
            <label>Observações (opcional):</label>
            <textarea id="observacao" class="form-control" rows="2"></textarea>
        </div>
        <div class="form-group">
            <label>Forma de pagamento:</label>
            <div id="paymentMethods">
                <div class="payment-option" data-payment="Dinheiro">💵 Dinheiro</div>
                <div class="payment-option" data-payment="PIX">📱 PIX</div>
                <div class="payment-option" data-payment="Cartão Débito">💳 Débito</div>
                <div class="payment-option" data-payment="Cartão Crédito">💎 Crédito</div>
            </div>
        </div>

        <h3>🍕 Itens do pedido</h3>
        <div id="itensPedido"></div>
        <button class="btn-adicionar" id="btnAdicionarPizza">+ Adicionar Pizza</button>
        <br>
        <button class="btn-enviar" id="btnFinalizarPedido">✅ Finalizar Pedido</button>
        
        <div style="margin-top: 20px;">
            <a href="/Home/AdminPedidos" class="btn-enviar" style="background:#3498db; text-decoration:none;">📊 Admin</a>
        </div>
    </div>

    <script>
        // ========================
        // 1. Variáveis globais
        // ========================
        let pizzas = [];
        let selectedPayment = "Dinheiro";

        // ========================
        // 2. Seleção de pagamento
        // ========================
        document.querySelectorAll('.payment-option').forEach(opt => {
            opt.addEventListener('click', () => {
                document.querySelectorAll('.payment-option').forEach(o => o.classList.remove('selected'));
                opt.classList.add('selected');
                selectedPayment = opt.dataset.payment;
            });
            // Marcar o primeiro como selecionado por padrão
            if (opt.dataset.payment === selectedPayment) opt.classList.add('selected');
        });

        // ========================
        // 3. Adicionar item visualmente
        // ========================
        function adicionarItemPedido() {
            const container = document.getElementById('itensPedido');
            const itemDiv = document.createElement('div');
            itemDiv.className = 'item-pedido';
            itemDiv.innerHTML = `
                <select class="sabor-select" style="margin-right:10px">
                    <option value="">-- Selecione --</option>
                    ${pizzas.map(p => `<option value="${p.name}" data-preco="${p.price}">${p.name} - R$ ${p.price}</option>`).join('')}
                </select>
                <select class="tamanho-select" style="margin-right:10px">
                    <option value="Pequena">Pequena</option>
                    <option value="Média">Média (+R$5)</option>
                    <option value="Grande">Grande (+R$10)</option>
                </select>
                <input type="number" class="qtd-input" value="1" min="1" style="width:70px">
                <button type="button" class="remover-item" style="margin-left:10px">Remover</button>
            `;
            // Evento para remover este item
            itemDiv.querySelector('.remover-item').addEventListener('click', () => itemDiv.remove());
            container.appendChild(itemDiv);
        }

        // ========================
        // 4. Finalizar pedido
        // ========================
        async function finalizarPedido() {
            const itens = [];
            document.querySelectorAll('.item-pedido').forEach(item => {
                const sabor = item.querySelector('.sabor-select')?.value;
                const tamanho = item.querySelector('.tamanho-select')?.value;
                const quantidade = parseInt(item.querySelector('.qtd-input')?.value || 0);
                if (sabor && quantidade > 0) {
                    itens.push({ sabor, tamanho, quantidade });
                }
            });

            if (itens.length === 0) {
                alert("Adicione pelo menos uma pizza ao pedido!");
                return;
            }

            const nomeCliente = document.getElementById('nomeCliente').value.trim();
            const endereco = document.getElementById('endereco').value.trim();
            const telefone = document.getElementById('telefone').value.trim();

            if (!nomeCliente || !endereco || !telefone) {
                alert("Preencha nome, endereço e telefone!");
                return;
            }

            const pedido = {
                nomeCliente,
                endereco,
                telefone,
                observacao: document.getElementById('observacao').value,
                metodoPagamento: selectedPayment,
                itens
            };

            const res = await fetch('/Home/FazerPedido', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(pedido)
            });

            if (res.ok) {
                const html = await res.text();
                document.body.innerHTML = html;
            } else {
                alert("Erro ao enviar pedido. Tente novamente.");
            }
        }

        // ========================
        // 5. Carregar cardápio da API
        // ========================
        async function carregarCardapio() {
            const container = document.getElementById('pizzas-list');
            container.innerHTML = "Carregando...";
            try {
                const res = await fetch('/api/pizza');
                if (!res.ok) throw new Error('Falha na API');
                pizzas = await res.json();
                if (!pizzas.length) throw new Error('Nenhuma pizza encontrada');
                container.innerHTML = pizzas.map(p => `
                    <div class="pizza-card">
                        <h3>${p.name}</h3>
                        <div class="price">R$ ${p.price.toFixed(2)}</div>
                        <div>${p.isVegetarian ? '🌱 Vegetariana' : '🍖 Tradicional'}</div>
                    </div>
                `).join('');
            } catch (err) {
                container.innerHTML = "<p style='color:red'>Erro ao carregar cardápio. Recarregue a página.</p>";
            }
        }

        // ========================
        // 6. Inicializar eventos
        // ========================
        document.getElementById('btnAdicionarPizza').addEventListener('click', adicionarItemPedido);
        document.getElementById('btnFinalizarPedido').addEventListener('click', finalizarPedido);

        // Inicializar página
        carregarCardapio();
    </script>
</body>
</html>

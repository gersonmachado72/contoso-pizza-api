@using ContosoPizza.Models
@model List<Pedido>
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Admin - ContosoPizza</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .container { max-width: 1200px; margin: 0 auto; padding: 20px; position: relative; z-index: 1; }
        .header-admin { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; flex-wrap: wrap; gap: 10px; }
        .btn-voltar { background: #e67e22; color: white; padding: 10px 20px; border-radius: 25px; text-decoration: none; }
        .btn-logout { background: #e74c3c; color: white; padding: 10px 20px; border-radius: 25px; text-decoration: none; }
        .pedido-card { background: white; border-radius: 12px; padding: 20px; margin-bottom: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
        
        @@media (max-width: 768px) {
            .container { padding: 10px; }
            .header-admin { flex-direction: column; align-items: stretch; text-align: center; }
            .btn-voltar, .btn-logout { text-align: center; }
        }
    </style>
</head>
<body>
    <div class="background-blur"></div>
    <div class="container">
        <div class="header-admin">
            <a href="/AdminPizzas" class="btn-voltar" style="background:#9b59b6;">🖼️ Fotos das Pizzas</a>
            <a href="/AdminAvaliacoes" class="btn-voltar" style="background:#9b59b6;">⭐ Avaliações</a>
            <a href="/Home/Index" class="btn-voltar">← Voltar ao Cardápio</a>
            <a href="/Home/DownloadRelatorio" class="btn-voltar" style="background:#27ae60;">📥 Baixar Relatório CSV</a>
            <a href="/Home/Logout" class="btn-logout">Sair</a>
        </div>
        <h1>📊 Gerenciamento de Pedidos</h1>
        <p>Total de pedidos: @Model.Count</p>
        
        @foreach (var pedido in Model)
        {
            <div class="pedido-card">
                <div><strong>Pedido #@pedido.Id</strong> - @pedido.DataPedido.ToString("dd/MM/yyyy HH:mm")</div>
                <div><strong>Cliente:</strong> @pedido.NomeCliente</div>
                <div><strong>Endereço:</strong> @pedido.Endereco</div>
                <div><strong>Telefone:</strong> @pedido.Telefone</div>
                <div><strong>Total:</strong> R$ @pedido.ValorTotal.ToString("F2")</div>
                <div><strong>Status:</strong> @pedido.Status</div>
                
                <form method="post" action="/Home/AtualizarStatus" style="margin-top: 15px;">
                    <input type="hidden" name="id" value="@pedido.Id">
                    <select name="status">
                        <option value="Preparando" @(pedido.Status == "Preparando" ? "selected" : "")>🔧 Preparando</option>
                        <option value="Saiu para entrega" @(pedido.Status == "Saiu para entrega" ? "selected" : "")>🚚 Saiu para entrega</option>
                        <option value="Finalizado" @(pedido.Status == "Finalizado" ? "selected" : "")>✅ Finalizado</option>
                    </select>
                    <input type="text" name="entregador" placeholder="Entregador" value="@pedido.EntregadorNome">
                    <label>
                        <input type="checkbox" name="pagamentoConfirmado" value="true" @(pedido.PagamentoConfirmado ? "checked" : "")> Pagamento confirmado
                    </label>
                    <button type="submit">Atualizar</button>
                </form>
            </div>
        }
    </div>
<script src="/js/whatsapp.js" data-number="@Environment.GetEnvironmentVariable("WhatsAppNumber")"></script>
</body>
</html>

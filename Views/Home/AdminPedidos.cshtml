@using ContosoPizza.Models
@model List<Pedido>
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Admin - ContosoPizza</title>
    <link rel="stylesheet" href="/css/style.css">
    <div style="text-align: right; margin-bottom: 20px;">
    <span>Bem-vindo, @User.Identity.Name!</span>
    <a href="/Home/Logout" class="btn-logout" style="background:#e74c3c; color:white; padding:5px 15px; border-radius:15px; margin-left:10px;">Sair</a>
</div>
    <style>
        .container { max-width: 1200px; margin: 0 auto; padding: 20px; }
        .pedido-card { background: white; border-radius: 12px; padding: 20px; margin-bottom: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
        .status { display: inline-block; padding: 4px 12px; border-radius: 20px; font-weight: bold; }
        .status-Preparando { background: #f39c12; color: white; }
        .status-Saiu_para_entrega { background: #3498db; color: white; }
        .status-Finalizado { background: #27ae60; color: white; }
        .badge-pago { background: #27ae60; color: white; padding: 2px 8px; border-radius: 12px; }
        .badge-pendente { background: #e74c3c; color: white; padding: 2px 8px; border-radius: 12px; }
        .btn-voltar { display: inline-block; background: #e67e22; color: white; padding: 10px 20px; border-radius: 25px; text-decoration: none; margin-bottom: 20px; }
        .btn-atualizar { background: #27ae60; color: white; border: none; padding: 5px 15px; border-radius: 20px; cursor: pointer; }
    </style>
</head>
<body>
    <div class="container">
        <a href="/Home/Index" class="btn-voltar">← Voltar ao Cardápio</a>
        <h1>📊 Gerenciamento de Pedidos</h1>
        <p>Total de pedidos: @Model.Count</p>
        
        @if (!Model.Any())
        {
            <p>Nenhum pedido realizado ainda.</p>
        }
        
        @foreach (var pedido in Model)
        {
            <div class="pedido-card">
                <div><strong>Pedido #@pedido.Id</strong> - @pedido.DataPedido.ToString("dd/MM/yyyy HH:mm")</div>
                <div><strong>Cliente:</strong> @pedido.NomeCliente</div>
                <div><strong>Endereço:</strong> @pedido.Endereco</div>
                <div><strong>Telefone:</strong> @pedido.Telefone</div>
                <div><strong>Observação:</strong> @(string.IsNullOrEmpty(pedido.Observacao) ? "Nenhuma" : pedido.Observacao)</div>
                <div><strong>Pagamento:</strong> @pedido.MetodoPagamento 
                    <span class="@(pedido.PagamentoConfirmado ? "badge-pago" : "badge-pendente")">
                        @(pedido.PagamentoConfirmado ? "✅ Pago" : "⏳ Pendente")
                    </span>
                </div>
                <div><strong>Status:</strong> <span class="status status-@(pedido.Status?.Replace(" ", "_"))">@pedido.Status</span></div>
                <div><strong>Entregador:</strong> @(string.IsNullOrEmpty(pedido.EntregadorNome) ? "Não atribuído" : pedido.EntregadorNome)</div>
                <div><strong>Total:</strong> R$ @pedido.ValorTotal.ToString("F2")</div>
                
                <form method="post" action="/Home/AtualizarStatus" style="margin-top: 15px;">
                    <input type="hidden" name="id" value="@pedido.Id">
                    <select name="status">
                        <option value="Preparando" @(pedido.Status == "Preparando" ? "selected" : "")>🔧 Preparando</option>
                        <option value="Saiu para entrega" @(pedido.Status == "Saiu para entrega" ? "selected" : "")>🚚 Saiu para entrega</option>
                        <option value="Finalizado" @(pedido.Status == "Finalizado" ? "selected" : "")>✅ Finalizado</option>
                    </select>
                    <input type="text" name="entregador" placeholder="Nome do entregador" value="@pedido.EntregadorNome">
                    <label>
                        <input type="checkbox" name="pagamentoConfirmado" value="true" @(pedido.PagamentoConfirmado ? "checked" : "")> Pagamento confirmado
                    </label>
                    <button type="submit" class="btn-atualizar">Atualizar</button>
                </form>
            </div>
        }
    </div>
</body>
</html>

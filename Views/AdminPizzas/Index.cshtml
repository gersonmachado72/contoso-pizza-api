@model List<ContosoPizza.Models.Pizza>
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin - Fotos das Pizzas</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .container { max-width: 1200px; margin: 0 auto; padding: 20px; }
        .header-admin { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
        .btn-voltar { background: #e67e22; color: white; padding: 10px 20px; border-radius: 25px; text-decoration: none; }
        .pizzas-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 20px; }
        .pizza-card { background: white; border-radius: 12px; padding: 15px; text-align: center; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
        .pizza-img { width: 100%; height: 150px; object-fit: cover; border-radius: 8px; margin-bottom: 10px; background: #f0f0f0; display: flex; align-items: center; justify-content: center; }
        .pizza-img img { max-width: 100%; max-height: 100%; border-radius: 8px; }
        .no-img { color: #999; font-size: 0.8rem; }
        .btn-upload { background: #27ae60; color: white; border: none; padding: 5px 10px; border-radius: 15px; cursor: pointer; margin-top: 10px; }
        .btn-remove { background: #e74c3c; color: white; border: none; padding: 5px 10px; border-radius: 15px; cursor: pointer; margin-top: 10px; }
        .success { background: #d4edda; color: #155724; padding: 10px; border-radius: 8px; margin-bottom: 20px; }
        .error { background: #f8d7da; color: #721c24; padding: 10px; border-radius: 8px; margin-bottom: 20px; }
    </style>
</head>
<body>
    <div class="background-blur"></div>
    <div class="container">
        <div class="header-admin">
            <a href="/Home/AdminPedidos" class="btn-voltar">← Voltar para Pedidos</a>
            <a href="/Home/Index" class="btn-voltar">← Voltar ao Cardápio</a>
        </div>
        <h1>🖼️ Gerenciar Fotos das Pizzas</h1>
        
        @if (TempData["Success"] != null)
        {
            <div class="success">@TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="error">@TempData["Error"]</div>
        }
        
        <div class="pizzas-grid">
            @foreach (var pizza in Model)
            {
                <div class="pizza-card">
                    <div class="pizza-img">
                        @if (!string.IsNullOrEmpty(pizza.ImageUrl))
                        {
                            <img src="@pizza.ImageUrl" alt="@pizza.Name">
                        }
                        else
                        {
                            <div class="no-img">🍕 Sem foto</div>
                        }
                    </div>
                    <h3>@pizza.Name</h3>
                    <p>R$ @pizza.Price.ToString("F2")</p>
                    
                    <form method="post" action="/AdminPizzas/UploadFoto/@pizza.Id" enctype="multipart/form-data">
                        <input type="file" name="foto" accept="image/*" required style="margin: 10px 0;">
                        <button type="submit" class="btn-upload">📤 Enviar Foto</button>
                    </form>
                    
                    @if (!string.IsNullOrEmpty(pizza.ImageUrl))
                    {
                        <form method="post" action="/AdminPizzas/RemoverFoto/@pizza.Id" onsubmit="return confirm('Remover foto da @pizza.Name?')">
                            <button type="submit" class="btn-remove">🗑️ Remover Foto</button>
                        </form>
                    }
                </div>
            }
        </div>
    </div>
</body>
</html>
